---
title: ""
layout: layouts/base.njk
pagination:
  data: collections.posts
  size: 12
  alias: posts
permalink: "{% if pagination.pageNumber == 0 %}/{% else %}/page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---
<div class="home">
  <div class="home-intro">
    <h1>{{ site.title }}</h1>
    <p>{{ site.description }}</p>
  </div>

  <div class="post-list">
    {% for post in posts %}
    <article class="post-card">
      {% if post.data.featuredImage %}
      <a href="{{ post.url }}" class="post-card-image">
        <img src="{{ post.data.featuredImage }}" alt="{{ post.data.title }}" loading="lazy" decoding="async">
      </a>
      {% endif %}
      <div class="post-card-content">
        <h2 class="post-card-title">
          <a href="{{ post.url }}">{{ post.data.title }}</a>
        </h2>
        <time class="post-card-date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
        {% if post.data.excerpt %}
        <p class="post-card-excerpt">{{ post.data.excerpt }}</p>
        {% endif %}
        {% if post.data.tags %}
        <div class="post-card-tags">
          {% for tag in post.data.tags | limit(4) %}
          <a href="/tag/{{ tag | slugify }}/" class="tag-badge tag-badge-sm">{{ tag }}</a>
          {% endfor %}
        </div>
        {% endif %}
      </div>
    </article>
    {% endfor %}
  </div>

  {% if pagination.pages.length > 1 %}
  <nav class="pagination" aria-label="Post pagination">
    {% if pagination.href.previous %}
    <a href="{{ pagination.href.previous }}" class="pagination-link pagination-prev">Newer posts</a>
    {% endif %}
    <span class="pagination-info">Page {{ pagination.pageNumber + 1 }} of {{ pagination.pages.length }}</span>
    {% if pagination.href.next %}
    <a href="{{ pagination.href.next }}" class="pagination-link pagination-next">Older posts</a>
    {% endif %}
  </nav>
  {% endif %}
</div>
